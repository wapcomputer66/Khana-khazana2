// Restaurant Billing System Schema - Multi-Tenant

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Restaurant {
  id          String     @id @default(cuid())
  name        String
  address     String?
  phone       String?
  gstNumber   String?
  email       String?
  isActive    Boolean    @default(true)
  users       User[]
  categories  Category[]
  menuItems   MenuItem[]
  orders      Order[]
  settings    Settings?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model User {
  id            String      @id @default(cuid())
  email         String      @unique
  name          String
  password      String
  role          String      @default("staff") // admin, staff, cashier
  restaurantId  String
  restaurant    Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orders        Order[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([email, restaurantId])
}

model Category {
  id           String       @id @default(cuid())
  name         String
  description  String?
  isActive     Boolean      @default(true)
  sortOrder    Int          @default(0)
  restaurantId  String
  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  menuItems    MenuItem[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([name, restaurantId])
}

model MenuItem {
  id           String       @id @default(cuid())
  name         String
  description  String?
  price        Float
  categoryId   String
  category     Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  restaurantId String
  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  isActive     Boolean      @default(true)
  image        String?
  stock        Int          @default(0)
  unit         String?      // pcs, kg, etc.
  orderItems   OrderItem[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([name, categoryId, restaurantId])
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String
  customerName    String?
  customerPhone   String?
  tableNumber     String?
  subtotal        Float
  tax             Float       @default(0)
  discount        Float       @default(0)
  totalAmount     Float
  paymentMethod   String?     // cash, card, upi, etc.
  paymentStatus   String      @default("pending") // pending, paid, partial
  orderStatus     String      @default("active") // active, completed, cancelled
  items           OrderItem[]
  kots            KOT[]
  createdById     String
  createdBy       User        @relation(fields: [createdById], references: [id])
  restaurantId    String
  restaurant      Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([orderNumber, restaurantId])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId  String
  menuItem    MenuItem @relation(fields: [menuItemId], references: [id])
  quantity    Int
  price       Float     // price at time of order
  subtotal    Float
  notes       String?
  isPrinted   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model KOT {
  id           String   @id @default(cuid())
  kotNumber    String
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items        KOTItem[]
  status       String   @default("pending") // pending, preparing, ready, served
  notes        String?
  printCount   Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now())
}

model KOTItem {
  id        String   @id @default(cuid())
  kotId     String
  kot       KOT      @relation(fields: [kotId], references: [id], onDelete: Cascade)
  itemId    String
  itemName  String
  quantity  Int
  notes     String?
  createdAt DateTime @default(now())
}

model Settings {
  id              String      @id @default(cuid())
  restaurantName  String      @default("My Restaurant")
  address         String?
  phone           String?
  gstNumber       String?
  taxRate         Float       @default(0)
  currency        String      @default("₹")
  printerType     String      @default("thermal") // thermal, bluetooth
  printerName     String?
  paperWidth      Int         @default(80) // 58mm or 80mm
  kotCopies       Int         @default(1)
  billCopies      Int         @default(1)
  showLogo        Boolean     @default(true)
  restaurantId    String      @unique
  restaurant      Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}
